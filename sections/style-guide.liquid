{% comment %}
  AMK Krishna Rice — Style Guide Section
  All values consume CSS custom properties from assets/base.css.
  Zero hardcoded hex values in CSS rules.
{% endcomment %}

<style>
  /* ── Page shell ──────────────────────────────────────── */
  .sg-page {
    background: var(--color-surface-base);
    color: var(--color-text-primary);
    font-family: var(--font-body);
  }

  /* ── Hero ────────────────────────────────────────────── */
  .sg-hero {
    background: var(--color-brand-secondary);
    padding-block: var(--spacing-11);
    text-align: center;
  }
  .sg-hero__eyebrow {
    font-family: var(--font-body);
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-brand-primary);
    margin-bottom: var(--spacing-3);
  }
  .sg-hero__title {
    font-family: var(--font-heading);
    font-size: var(--font-size-h1);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    color: var(--color-text-inverse);
    margin-bottom: var(--spacing-4);
  }
  .sg-hero__tagline {
    font-family: var(--font-heading);
    font-size: var(--font-size-h4);
    font-weight: var(--font-weight-medium);
    font-style: italic;
    color: var(--color-surface-warm);
  }
  .sg-hero__meta {
    margin-top: var(--spacing-5);
    font-size: var(--font-size-small);
    color: var(--color-text-inverse);
    opacity: 0.4;
  }

  /* ── Section structure ───────────────────────────────── */
  .sg-section {
    padding-block: var(--spacing-10);
    border-bottom: 1px solid var(--color-border-default);
  }
  .sg-section:last-child { border-bottom: none; }

  .sg-section__header {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-8);
    padding-bottom: var(--spacing-4);
    border-bottom: 2px solid var(--color-brand-primary);
  }
  .sg-section__num {
    font-family: var(--font-heading);
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-bold);
    color: var(--color-brand-primary);
    line-height: 1;
    opacity: 0.25;
  }
  .sg-section__heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    color: var(--color-text-primary);
    margin: 0;
  }

  /* ── Subsection label ────────────────────────────────── */
  .sg-sub { margin-bottom: var(--spacing-6); }
  .sg-sub + .sg-sub { margin-top: var(--spacing-9); }
  .sg-sub__label {
    font-family: var(--font-body);
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-4);
  }

  /* ── Colour swatches ─────────────────────────────────── */
  .sg-palette {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--spacing-4);
  }
  .sg-swatch {
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border-default);
  }
  .sg-swatch__color { height: 80px; width: 100%; display: block; }
  .sg-swatch__info {
    padding: var(--spacing-3);
    background: var(--color-surface-base);
  }
  .sg-swatch__name {
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
    margin: 0 0 2px;
  }
  .sg-swatch__token,
  .sg-swatch__hex {
    font-family: var(--font-mono);
    font-size: var(--font-size-caption);
    display: block;
  }
  .sg-swatch__token { color: var(--color-text-muted); }
  .sg-swatch__hex   { color: var(--color-text-secondary); }

  /* ── Typeface cards ──────────────────────────────────── */
  .sg-typeface-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-6);
    margin-bottom: var(--spacing-8);
  }
  .sg-typeface-card {
    padding: var(--spacing-6);
    background: var(--color-surface-warm);
    border-radius: var(--radius-lg);
  }
  .sg-typeface-card__role {
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-3);
    display: block;
  }
  .sg-typeface-card__family {
    font-size: var(--font-size-h3);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    margin: 0 0 var(--spacing-2);
  }
  .sg-typeface-card__specimen {
    font-size: var(--font-size-body);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    margin: 0;
  }
  .sg-typeface-card__weights {
    margin-top: var(--spacing-4);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  /* ── Type scale ──────────────────────────────────────── */
  .sg-scale-item {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-6);
    padding-block: var(--spacing-5);
    border-bottom: 1px solid var(--color-border-default);
  }
  .sg-scale-item:last-child { border-bottom: none; }
  .sg-scale-meta {
    min-width: 220px;
    flex-shrink: 0;
  }
  .sg-scale-meta__token {
    font-family: var(--font-mono);
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 2px;
  }
  .sg-scale-meta__spec {
    font-size: var(--font-size-caption);
    color: var(--color-border-strong);
    display: block;
  }

  /* ── Spacing scale ───────────────────────────────────── */
  .sg-space-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-5);
    margin-bottom: var(--spacing-3);
  }
  .sg-space-item__bar {
    background: var(--color-brand-primary);
    height: 24px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }
  .sg-space-item__label {
    font-family: var(--font-mono);
    font-size: var(--font-size-caption);
    color: var(--color-text-secondary);
  }

  /* ── Border radius ───────────────────────────────────── */
  .sg-radius-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-8);
    align-items: flex-end;
  }
  .sg-radius-item { text-align: center; }
  .sg-radius-item__demo {
    width: 80px;
    height: 80px;
    background: var(--color-surface-warm);
    border: 2px solid var(--color-brand-primary);
    margin-bottom: var(--spacing-3);
  }
  .sg-radius-item__label {
    font-family: var(--font-mono);
    font-size: var(--font-size-caption);
    color: var(--color-text-secondary);
    display: block;
  }
  .sg-radius-item__value {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    display: block;
  }

  /* ── Shadows ─────────────────────────────────────────── */
  .sg-shadow-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--spacing-6);
  }
  .sg-shadow-item {
    background: var(--color-surface-base);
    border-radius: var(--radius-md);
    padding: var(--spacing-6);
    text-align: center;
  }
  .sg-shadow-item__token {
    font-family: var(--font-mono);
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    display: block;
    margin-bottom: var(--spacing-2);
  }

  /* ── Buttons ─────────────────────────────────────────── */
  .sg-btn-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-4);
    align-items: center;
    margin-bottom: var(--spacing-5);
  }
  .sg-btn-row:last-child { margin-bottom: 0; }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    line-height: 1;
    padding: var(--spacing-3) var(--spacing-6);
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition:
      background var(--transition-base),
      color var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }
  .btn--primary {
    background: var(--color-brand-primary);
    color: var(--color-text-inverse);
    border-color: var(--color-brand-primary);
  }
  .btn--primary:hover {
    background: var(--color-brand-primary-dark);
    border-color: var(--color-brand-primary-dark);
  }
  .btn--secondary {
    background: transparent;
    color: var(--color-brand-primary);
    border-color: var(--color-brand-primary);
  }
  .btn--secondary:hover { background: var(--color-brand-primary-soft); }
  .btn--ghost {
    background: transparent;
    color: var(--color-text-primary);
    border-color: var(--color-border-strong);
  }
  .btn--ghost:hover {
    border-color: var(--color-brand-primary);
    color: var(--color-brand-primary);
  }
  .btn--dark {
    background: var(--color-brand-secondary);
    color: var(--color-text-inverse);
    border-color: var(--color-brand-secondary);
  }
  .btn--dark:hover {
    background: var(--color-text-secondary);
    border-color: var(--color-text-secondary);
  }
  .btn--inverse {
    background: transparent;
    color: var(--color-text-inverse);
    border-color: var(--color-text-inverse);
  }
  .btn--lg {
    font-size: var(--font-size-body);
    padding: var(--spacing-4) var(--spacing-8);
  }
  .btn--sm {
    font-size: var(--font-size-caption);
    padding: var(--spacing-2) var(--spacing-4);
  }
  .btn:disabled,
  .btn[aria-disabled='true'] {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* ── Form elements ───────────────────────────────────── */
  .sg-form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-6);
  }
  .sg-field {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }
  .sg-label {
    font-size: var(--font-size-small);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-primary);
  }
  .sg-input,
  .sg-select,
  .sg-textarea {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--color-text-primary);
    background: var(--color-surface-base);
    border: 1.5px solid var(--color-border-default);
    border-radius: var(--radius-md);
    padding: var(--spacing-3) var(--spacing-4);
    width: 100%;
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }
  .sg-input:focus,
  .sg-select:focus,
  .sg-textarea:focus {
    border-color: var(--color-border-brand);
    box-shadow: 0 0 0 3px var(--color-brand-primary-soft);
  }
  .sg-input--error { border-color: var(--color-feedback-error); }
  .sg-input--error:focus { box-shadow: 0 0 0 3px var(--color-brand-primary-soft); }
  .sg-textarea { resize: vertical; min-height: 100px; }
  .sg-helper {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
  }
  .sg-helper--error { color: var(--color-feedback-error); }
  .sg-check-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
    cursor: pointer;
  }
  .sg-check-row input[type='checkbox'],
  .sg-check-row input[type='radio'] {
    width: 18px;
    height: 18px;
    accent-color: var(--color-brand-primary);
    cursor: pointer;
    flex-shrink: 0;
  }

  /* ── Badges ──────────────────────────────────────────── */
  .sg-badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-bottom: var(--spacing-4);
  }
  .sg-badge-row:last-child { margin-bottom: 0; }
  .badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    padding: var(--spacing-1) var(--spacing-3);
    border-radius: var(--radius-full);
    line-height: 1.5;
    border: 1.5px solid transparent;
  }
  .badge--brand   { background: var(--color-brand-primary);    color: var(--color-text-inverse); }
  .badge--accent  { background: var(--color-brand-accent);     color: var(--color-text-inverse); }
  .badge--sepia   { background: var(--color-brand-sepia);      color: var(--color-text-inverse); }
  .badge--success { background: var(--color-feedback-success); color: var(--color-text-inverse); }
  .badge--error   { background: var(--color-feedback-error);   color: var(--color-text-inverse); }
  .badge--soft    { background: var(--color-brand-primary-soft); color: var(--color-brand-primary); }
  .badge--warm    { background: var(--color-surface-warm);       color: var(--color-brand-sepia); }
  .badge--outline {
    background: transparent;
    color: var(--color-brand-primary);
    border-color: var(--color-brand-primary);
  }

  /* ── Usage guidelines ────────────────────────────────── */
  .sg-guidelines-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-6);
  }
  .sg-rule {
    padding: var(--spacing-5);
    border-radius: var(--radius-md);
    border-left: 4px solid;
  }
  .sg-rule--do   { background: var(--color-brand-primary-soft); border-left-color: var(--color-feedback-success); }
  .sg-rule--dont { background: var(--color-surface-warm);       border-left-color: var(--color-feedback-error); }
  .sg-rule__verdict {
    font-size: var(--font-size-label);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    margin-bottom: var(--spacing-4);
    margin-top: 0;
  }
  .sg-rule--do   .sg-rule__verdict { color: var(--color-feedback-success); }
  .sg-rule--dont .sg-rule__verdict { color: var(--color-feedback-error); }
  .sg-rule__text {
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    margin: 0;
  }
  .sg-rule__text + .sg-rule__text { margin-top: var(--spacing-2); }

  /* ── Token reference ─────────────────────────────────── */
  .sg-token-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--spacing-2);
  }
  .sg-token {
    font-family: var(--font-mono);
    font-size: var(--font-size-caption);
    color: var(--color-text-secondary);
    background: var(--color-surface-warm);
    padding: var(--spacing-2) var(--spacing-3);
    border-radius: var(--radius-sm);
    display: block;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 768px) {
    .sg-typeface-row,
    .sg-form-grid,
    .sg-guidelines-grid {
      grid-template-columns: 1fr;
    }
    .sg-scale-item { flex-direction: column; gap: var(--spacing-3); }
    .sg-scale-meta { min-width: unset; }
  }
</style>

<div class="sg-page">

  <!-- ══ HERO ══════════════════════════════════════════ -->
  <div class="sg-hero">
    <div class="container">
      <p class="sg-hero__eyebrow">Brand Design System — Internal Reference</p>
      <h1 class="sg-hero__title">AMK Krishna Rice</h1>
      <p class="sg-hero__tagline">"Truly! Softly!"</p>
      <p class="sg-hero__meta">Est. 1964 &nbsp;·&nbsp; Tamil Nadu &nbsp;·&nbsp; v1.0</p>
    </div>
  </div>

  <div class="container">

    <!-- ══ 01 · COLOUR SYSTEM ════════════════════════ -->
    <div class="sg-section">
      <div class="sg-section__header">
        <span class="sg-section__num">01</span>
        <h2 class="sg-section__heading">Colour System</h2>
      </div>

      <div class="sg-sub">
        <p class="sg-sub__label">Primary Brand Colours</p>
        <div class="sg-palette">
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-brand-primary);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Magenta</p>
              <span class="sg-swatch__token">--color-brand-primary</span>
              <span class="sg-swatch__hex">#C1006D</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-brand-secondary);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Near-Black</p>
              <span class="sg-swatch__token">--color-brand-secondary</span>
              <span class="sg-swatch__hex">#1A1A1A</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-surface-warm); border-bottom: 1px solid var(--color-border-default);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Warm Beige</p>
              <span class="sg-swatch__token">--color-surface-warm</span>
              <span class="sg-swatch__hex">#E8D4C8</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-surface-base); border-bottom: 1px solid var(--color-border-default);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">White</p>
              <span class="sg-swatch__token">--color-surface-base</span>
              <span class="sg-swatch__hex">#FFFFFF</span>
            </div>
          </div>
        </div>
      </div>

      <div class="sg-sub">
        <p class="sg-sub__label">Secondary / Supporting</p>
        <div class="sg-palette">
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-brand-primary-dark);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Magenta Dark</p>
              <span class="sg-swatch__token">--color-brand-primary-dark</span>
              <span class="sg-swatch__hex">#8E0050</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-brand-primary-soft); border-bottom: 1px solid var(--color-border-default);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Soft Pink</p>
              <span class="sg-swatch__token">--color-brand-primary-soft</span>
              <span class="sg-swatch__hex">#FCE4EC</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-brand-sepia);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Sepia</p>
              <span class="sg-swatch__token">--color-brand-sepia</span>
              <span class="sg-swatch__hex">#8B7355</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-brand-accent);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Purple</p>
              <span class="sg-swatch__token">--color-brand-accent</span>
              <span class="sg-swatch__hex">#3D3198</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-text-secondary);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Charcoal</p>
              <span class="sg-swatch__token">--color-text-secondary</span>
              <span class="sg-swatch__hex">#414042</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-border-default); border-bottom: 1px solid var(--color-border-default);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Light Grey</p>
              <span class="sg-swatch__token">--color-border-default</span>
              <span class="sg-swatch__hex">#E5E5E5</span>
            </div>
          </div>
        </div>
      </div>

      <div class="sg-sub">
        <p class="sg-sub__label">Text Colours</p>
        <div class="sg-palette">
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-text-primary);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Primary Text</p>
              <span class="sg-swatch__token">--color-text-primary</span>
              <span class="sg-swatch__hex">#1A1A1A</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-text-secondary);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Secondary Text</p>
              <span class="sg-swatch__token">--color-text-secondary</span>
              <span class="sg-swatch__hex">#414042</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-text-muted);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Muted / Meta</p>
              <span class="sg-swatch__token">--color-text-muted</span>
              <span class="sg-swatch__hex">#8B7355</span>
            </div>
          </div>
          <div class="sg-swatch">
            <span class="sg-swatch__color" style="background: var(--color-text-brand);"></span>
            <div class="sg-swatch__info">
              <p class="sg-swatch__name">Brand Emphasis</p>
              <span class="sg-swatch__token">--color-text-brand</span>
              <span class="sg-swatch__hex">#C1006D</span>
            </div>
          </div>
