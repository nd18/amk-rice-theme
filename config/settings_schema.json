      { "type": "color", "id": "color_surface_warm", "label": "Warm beige — section background", "default": "#E8D4C8" },
      { "type": "color", "id": "color_text", "label": "Primary text", "default": "#1A1A1A" },
      { "type": "color", "id": "color_text_secondary", "label": "Secondary text (charcoal)", "default": "#414042" },
